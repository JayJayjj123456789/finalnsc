# Smart Travel Planner - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# API Keys (Optional - system works without)
# ===========================================

# OpenRouter API Key (for AI-powered intent parsing)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# Tavily API Key (for web search)
# Get from: https://tavily.com
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxx

# ===========================================
# Neo4j Database (Optional - uses fallback data)
# ===========================================

# Local development
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# Neo4j Aura (Cloud)
# Format: bolt+s://xxxxx.databases.neo4j.io
NEO4J_URI=bolt+s://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_aura_password_here

# ===========================================
# Frontend
# ===========================================

# API URL (for production)
VITE_API_URL=https://your-backend.railway.app
